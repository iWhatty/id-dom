{
  "name": "id-dom",
  "version": "0.0.1",
  "description": "Deterministic DOM element getters by ID (typed, tiny, modern).",
  "author": "DR.WATT",
  "license": "SEE LICENSE IN LICENSE",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./min": {
      "import": "./dist/index.min.js",
      "default": "./dist/index.min.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iWhatty/id-dom.git"
  },
  "bugs": {
    "url": "https://github.com/iWhatty/id-dom/issues"
  },
  "homepage": "https://github.com/iWhatty/id-dom#readme",
  "keywords": [
    "dom",
    "getelementbyid",
    "typed-dom",
    "html",
    "vanilla-js",
    "browser",
    "shadow-dom",
    "utilities"
  ],
  "scripts": {
    "build": "node build.js",
    "prepublishOnly": "npm run build",
    "test": "vitest run --environment jsdom",
    "test:watch": "vitest --environment jsdom"
  },
  "devDependencies": {
    "esbuild": "^0.27.3",
    "jsdom": "^24.0.0",
    "vitest": "^3.1.2"
  },
  "engines": {
    "node": ">=18"
  }
}
