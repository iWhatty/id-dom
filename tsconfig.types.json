{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "declaration": true,
    "emitDeclarationOnly": true,
    "allowJs": true,
    "checkJs": false,
    "outDir": "./dist/types",
    "moduleResolution": "Node",
    "skipLibCheck": true,
    "rootDir": "./src"
  },
  "include": ["src/**/*.js"],
  "exclude": ["src/**/*.test.js", "dist", "node_modules"]
}
